{
  "name": "@pnm/core",
  "private": true,
  "version": "0.1.0",
  "description": "Shared core: WebAuthn ceremony helpers, COSE→Multikey conversion, DID verificationMethod builder, VTA REST client.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webauthn": {
      "types": "./dist/webauthn/index.d.ts",
      "import": "./dist/webauthn/index.js"
    },
    "./did": {
      "types": "./dist/did/index.d.ts",
      "import": "./dist/did/index.js"
    },
    "./vta": {
      "types": "./dist/vta/index.d.ts",
      "import": "./dist/vta/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "tsc -b --noEmit",
    "test": "tsc -b && node --test tests/*.mjs",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hpke/chacha20poly1305": "^1.8.0",
    "@hpke/core": "^1.9.0",
    "@noble/curves": "^2.2.0",
    "@openvtc/vti-didcomm-js": "^0.4.1",
    "@scure/base": "^1.1.9",
    "cbor-x": "^1.6.4"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
