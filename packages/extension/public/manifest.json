{
  "manifest_version": 3,
  "name": "PNM Wallet",
  "version": "0.1.0",
  "description": "Bridge between WebAuthn passkeys and VTA-managed DIDs.",
  "icons": {
    "16": "icon.svg",
    "32": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PNM Wallet",
    "default_icon": {
      "16": "icon.svg",
      "32": "icon.svg",
      "48": "icon.svg"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://admin.webvh.storm.ws/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["provider.js"],
      "matches": [
        "https://admin.webvh.storm.ws/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ],
  "permissions": ["storage", "offscreen", "notifications"],
  "host_permissions": [
    "https://admin.webvh.storm.ws/*",
    "https://webvh.storm.ws/*",
    "https://glenn.storm.ws/*"
  ]
}
