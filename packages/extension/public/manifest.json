{
  "manifest_version": 3,
  "name": "PNM Wallet",
  "version": "0.1.0",
  "description": "Bridge between WebAuthn passkeys and VTA-managed DIDs.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PNM Wallet"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://admin.webvh.storm.ws/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["provider.js"],
      "matches": [
        "https://admin.webvh.storm.ws/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ],
  "permissions": ["storage", "offscreen", "notifications"],
  "host_permissions": ["https://admin.webvh.storm.ws/*"]
}
