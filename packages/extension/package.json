{
  "name": "@openvtc/pnm-extension",
  "private": true,
  "version": "0.2.0",
  "description": "Manifest v3 browser extension shell sharing @openvtc/pnm-core.",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc -b && vite build && vite build -c vite.config.background.ts",
    "lint": "tsc -b",
    "render:icons": "scripts/render-icons.sh"
  },
  "dependencies": {
    "@openvtc/pnm-core": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0"
  }
}
